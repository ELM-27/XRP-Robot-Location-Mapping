from XRPLib.defaults import *
from XRPLib.board import Board
from XRPLib.reflectance import Reflectance
from XRPLib.differential_drive import DifferentialDrive
import time
import random
import math

board = Board.get_default_board()
reflectance = Reflectance.get_default_reflectance()
drive = DifferentialDrive.get_default_differential_drive()

SPEED           = 0.45
THRESH          = 0.05
BACKUP_TIME_MS  = 600
PAUSE_MS        = 80
TURN_EFFORT     = 0.45
YAW_INTERVAL_MS = 20
DEG_PER_MS      = 0.18

imu.calibrate()
heading = imu.get_yaw()
log_lines = []

def on_line():
    return (abs(reflectance.get_left()  - start_left)  >= THRESH or
            abs(reflectance.get_right() - start_right) >= THRESH)

def fmt1(v):
    return str(round(v, 1))

start_left  = reflectance.get_left()
start_right = reflectance.get_right()

while not board.is_button_pressed():
    drive.set_effort(SPEED, SPEED)
    t_start    = time.ticks_ms()
    t_last_yaw = t_start
    while (not board.is_button_pressed()) and (not on_line()):
        now = time.ticks_ms()
        if time.ticks_diff(now, t_last_yaw) >= YAW_INTERVAL_MS:
            heading = imu.get_yaw()
            log_lines.append("Drive: " + fmt1(heading))
            t_last_yaw = now
        time.sleep_ms(5)
    drive.stop()
    t_end = time.ticks_ms()
    segment_ms = time.ticks_diff(t_end, t_start)
    # Overwrite the drive entries with a single SegmentMs line
    # Remove drive entries we just added and replace with timed segment
    while log_lines and log_lines[-1].startswith("Drive:"):
        log_lines.pop()
    log_lines.append("Segment: " + str(segment_ms))
    if board.is_button_pressed():
        break
    time.sleep_ms(PAUSE_MS)

    log_lines.append("Reverse: " + fmt1(float(BACKUP_TIME_MS)))
    drive.set_effort(-SPEED, -SPEED)
    time.sleep_ms(BACKUP_TIME_MS)
    drive.stop()
    time.sleep_ms(PAUSE_MS)

    turn_deg = random.randint(-180, 180)
    direction = 1 if turn_deg >= 0 else -1
    abs_deg = abs(turn_deg)
    duration_ms = int(abs_deg / DEG_PER_MS)
    drive.set_effort(-direction * TURN_EFFORT, direction * TURN_EFFORT)
    yaw_before = imu.get_yaw()
    time.sleep_ms(duration_ms)
    drive.stop()
    time.sleep_ms(100)
    yaw_after = imu.get_yaw()
    actual_turn = yaw_after - yaw_before
    while actual_turn > 180:
        actual_turn = actual_turn - 360
    while actual_turn < -180:
        actual_turn = actual_turn + 360
    log_lines.append("Turn: " + fmt1(actual_turn))
    heading = imu.get_yaw()
    time.sleep_ms(PAUSE_MS)

    start_left  = reflectance.get_left()
    start_right = reflectance.get_right()

drive.stop()
f = open("movement_log.txt", "w")
for line in log_lines:
    f.write(line + "\n")
f.close()
print("Saved movement_log.txt (" + str(len(log_lines)) + " lines)")
print("Retrieve it via XRPCode Files tab.")
